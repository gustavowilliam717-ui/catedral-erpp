# Banco de dados
# Desenvolvimento rapido com SQLite:
# DATABASE_URL=sqlite:///./catedral_erp.db

# PostgreSQL local:
# Troque USUARIO, SENHA e NOME_DO_BANCO pelos dados criados no PostgreSQL/pgAdmin.
DATABASE_URL=postgresql+psycopg://USUARIO:SENHA@localhost:5432/NOME_DO_BANCO

# Seguranca / CORS
# Lista de origens permitidas, separadas por virgula. Em producao informe o
# dominio do frontend, ex: ALLOWED_ORIGINS=https://app.seudominio.com
# Vazio ou "*" libera todas as origens (use apenas em desenvolvimento).
ALLOWED_ORIGINS=

# Modo de desenvolvimento de autenticacao.
# Quando "true" E sem SMTP/Twilio configurados, os codigos de verificacao
# sao retornados na resposta da API (campos dev_code / dev_email_code /
# dev_sms_code) em vez de enviados. NUNCA use "true" em producao.
AUTH_DEV_MODE=false

# Codigos de verificacao
# O backend exige envio real por SMTP/SMS. Sem essas credenciais,
# cadastro/login retornam erro (a menos que AUTH_DEV_MODE=true).

# Email SMTP para enviar codigo de cadastro/login.
# Exemplos comuns:
# - Gmail/Workspace: SMTP_HOST=smtp.gmail.com, SMTP_PORT=587, SMTP_TLS=true
# - Brevo/SendGrid/Mailgun: use os dados SMTP fornecidos pelo provedor
EMAIL_PROVIDER=auto
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=
SMTP_TLS=true
SMTP_SSL=false
SMTP_TIMEOUT=8

# Email via API HTTPS (recomendado quando a hospedagem bloqueia SMTP).
# Resend usa POST https://api.resend.com/emails com Authorization: Bearer.
# Configure EMAIL_PROVIDER=resend para forcar este provedor.
RESEND_API_KEY=
RESEND_FROM="NEXT ERP <onboarding@resend.dev>"

# Provedor de SMS. Use "zenvia" ou "twilio".
SMS_PROVIDER=zenvia

# SMS via Zenvia para enviar codigo no celular.
# Gere o token em https://app.zenvia.com/home/api
# Configure o canal/remetente em https://app.zenvia.com/home/credentials
ZENVIA_API_TOKEN=
ZENVIA_FROM=
ZENVIA_API_URL=https://api.zenvia.com/v2/channels/sms/messages

# SMS via Twilio para enviar codigo no celular.
# TWILIO_FROM_NUMBER deve estar em formato internacional, ex: +15551234567
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# Chat de IA
OPENAI_API_KEY=

# Fiscal / SEFAZ via Focus NFe
# Homologacao: https://homologacao.focusnfe.com.br
# Producao: https://api.focusnfe.com.br
FISCAL_PROVIDER=focus_nfe
FISCAL_ENVIRONMENT=homologacao
FOCUS_NFE_BASE_URL=https://homologacao.focusnfe.com.br
# Opcional: tambem e possivel cadastrar o token pela tela Fiscal do ERP.
FOCUS_NFE_TOKEN=

# Integracao Mercado Livre (OAuth 2.0)
# Crie uma aplicacao em https://developers.mercadolivre.com.br/ (Minhas aplicacoes)
# e copie o App ID (Client ID) e a Secret Key (Client Secret).
ML_APP_ID=
ML_SECRET_KEY=
# Precisa ser EXATAMENTE igual a "URI de redirect" cadastrada na aplicacao do ML.
# O Mercado Livre exige HTTPS. Em desenvolvimento use um tunel (ex: ngrok) e aponte
# o redirect para .../mercadolivre/callback. Em producao use o dominio do ERP.
# Ex: ML_REDIRECT_URI=https://SEU-DOMINIO/mercadolivre/callback
ML_REDIRECT_URI=
# Para onde o usuario volta no frontend depois de conectar (opcional).
ML_FRONTEND_RETURN_URL=/
# Avancado (defaults ja apontam para o Brasil):
# ML_AUTH_URL=https://auth.mercadolivre.com.br/authorization
# ML_API_BASE=https://api.mercadolibre.com

# Integracao Shopee Open Platform
# Crie um app na Shopee Open Platform e copie Partner ID, Partner Key e Shop ID.
SHOPEE_PARTNER_ID=
SHOPEE_PARTNER_KEY=
SHOPEE_SHOP_ID=
# O redirect precisa apontar para o callback do backend.
SHOPEE_REDIRECT_URI=http://127.0.0.1:8000/shopee/callback
# Para onde o usuario volta no frontend depois de concluir a autorizacao.
SHOPEE_FRONTEND_RETURN_URL=/
# Defaults editaveis pela tela de integracao.
SHOPEE_ENVIRONMENT=production
SHOPEE_AUTH_URL=https://partner.shopeemobile.com/api/v2/shop/auth_partner
SHOPEE_TOKEN_URL=https://partner.shopeemobile.com/api/v2/auth/token/get
SHOPEE_REFRESH_URL=https://partner.shopeemobile.com/api/v2/auth/access_token/get
SHOPEE_SHOP_INFO_URL=https://partner.shopeemobile.com/api/v2/shop/get_shop_info
SHOPEE_API_BASE=https://partner.shopeemobile.com
