[Unit]
Description=Catedral ERP (FastAPI/Uvicorn)
After=network.target postgresql.service

[Service]
Type=simple
User=catedral
Group=catedral
WorkingDirectory=/opt/catedral-erp/backend
# O app carrega o backend/.env automaticamente (python-dotenv).
ExecStart=/opt/catedral-erp/venv/bin/python -m uvicorn app.main:app \
    --host 127.0.0.1 --port 8000 \
    --workers 2 \
    --proxy-headers --forwarded-allow-ips=127.0.0.1
Restart=on-failure
RestartSec=5

[Install]
WantedBy=multi-user.target
