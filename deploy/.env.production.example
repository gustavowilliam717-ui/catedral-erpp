# ==========================================================================
# Catedral ERP — variaveis de PRODUCAO (copie para backend/.env na VPS)
# ==========================================================================

# --- Banco de dados (PostgreSQL na propria VPS) ---
# Troque SENHA pela senha do usuario do banco criado no passo do PostgreSQL.
DATABASE_URL=postgresql+psycopg://catedral:SENHA@localhost:5432/catedral_erp

# --- Seguranca / CORS ---
# O frontend e servido pelo mesmo dominio do backend, entao normalmente basta
# informar o proprio dominio. Separe por virgula se houver mais de um.
ALLOWED_ORIGINS=https://SEU_DOMINIO.com,https://www.SEU_DOMINIO.com

# NUNCA "true" em producao — exige envio real de codigos.
AUTH_DEV_MODE=false

# --- Email (obrigatorio em producao para cadastro/login) ---
SMTP_HOST=smtp.seuprovedor.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=nao-responda@SEU_DOMINIO.com
SMTP_TLS=true
SMTP_SSL=false

# --- SMS via Twilio (obrigatorio para o cadastro de 2 fatores) ---
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# --- Chat de IA (opcional) ---
OPENAI_API_KEY=
